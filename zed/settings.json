// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "default_config_options": {
        "mode": "agent",
        "model": "claude-sonnet-5"
      },
      "type": "registry"
    }
  },
  "show_edit_predictions": false,
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "never",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "never",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "languages": {
    "HTML": {
      "preferred_line_length": 120,
    },
    "Rust": {
      "format_on_save": "on",
    },
    "JavaScript": {
      "preferred_line_length": 120,
      "soft_wrap": "none",
      "hard_tabs": false,
      "tab_size": 2,
    },
    "Python": {
      "colorize_brackets": false,
      "language_servers": ["ty", "!basedpyright"],
      "formatter": {
        "language_server": { "name": "ruff" },
      },
      "inlay_hints": {
        "show_background": false,
        "enabled": true,
      },
      "preferred_line_length": 120,
      "soft_wrap": "none",
    },
  },
  "ssh_connections": [
    {
      "host": "192.168.86.89",
      "username": "vanitas",
      "port": 2001,
      "args": ["-i", "/home/acme/.ssh/vanitas"],
      "projects": [
        {
          "paths": ["/home/vanitas/./"],
        },
      ],
      "nickname": "vanitas",
    },
  ],
  "gutter": {
    "line_numbers": true,
  },
  "disable_ai": false,
  "inlay_hints": {
    "enabled": true,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false,
    },
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "telemetry": {
    "metrics": false,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "elblur",
    "dark": "One Dark",
  },
}
